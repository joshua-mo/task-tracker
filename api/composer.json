{
  "name": "neoan.io/rest-api-starter-project",
  "description": "Basic neoan.io Lenkrad starter kit with authentication",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Stefan Roehrl",
      "email": "neoan@neoan.us"
    }
  ],
  "require": {
    "neoan.io/core": "^0",
    "neoan.io/legacy-db-adapter": "1.*",
    "neoan3-apps/stateless": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Config\\": "config/",
      "Commands\\": "commands/"
    }
  },
  "scripts": {
    "format:php": "php-cs-fixer fix --config=.php-cs-fixer.dist.php",
    "format:php:check": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.dist.php"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.66"
  }
}
